# Paste these in Render Dashboard → writeai-api → Environment
# Replace placeholders before saving.

NODE_ENV=production
DATABASE_URL=postgresql://USER:PASS@HOST/neondb?sslmode=require
JWT_SECRET=generate-a-long-random-string
JWT_EXPIRES_IN=30d

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://writeai-api.onrender.com/auth/google/callback

FRONTEND_URL=https://demo.yourdomain.com
EXTENSION_ORIGIN=chrome-extension://YOUR_EXTENSION_ID

ADMIN_EMAILS=you@gmail.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong-password-here
ADMIN_DISPLAY_NAME=WriteAI Admin

OPENAI_API_KEY=
GEMINI_API_KEY=

# Redis optional — leave unset on free demo
# REDIS_URL=
