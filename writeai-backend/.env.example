PORT=3000
DATABASE_URL=postgresql://user:pass@localhost:5432/writeai
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=30d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

OPENAI_API_KEY=
GEMINI_API_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

FRONTEND_URL=http://localhost:3000
EXTENSION_ORIGIN=chrome-extension://YOUR_EXTENSION_ID

# Comma-separated emails that get admin role on Google sign-in (extension users only)
ADMIN_EMAILS=admin@example.com

# Master panel login (stored in panel_admins table — run npm run seed:admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_DISPLAY_NAME=WriteAI Admin
ADMIN_SESSION_EXPIRES_IN=8h
