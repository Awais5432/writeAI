{
  "name": "writeai-backend",
  "version": "1.0.0",
  "description": "WriteAI API — AI writing assistant backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed:admin": "node scripts/seed-admin.js",
    "setup": "node scripts/setup.js",
    "docker:up": "docker compose -f ../docker-compose.yml up -d",
    "docker:down": "docker compose -f ../docker-compose.yml down",
    "build:hostinger": "node ../scripts/build-hostinger.js",
    "zip:hostinger": "node ../scripts/zip-hostinger-node.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "openai": "^6.44.0",
    "pg": "^8.21.0",
    "redis": "^6.0.0",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
